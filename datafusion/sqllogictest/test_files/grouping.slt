statement ok
CREATE TABLE test (c1 VARCHAR,c2 VARCHAR,c3 INT) as values
('a','A',1), ('b','B',2)

# grouping_with_grouping_sets
query TTIIII
select
  c1,
  c2,
  grouping(c1) as g0,
  grouping(c2) as g1,
  grouping(c1, c2) as g2,
  grouping(c2, c1) as g3
from
  test
group by
  grouping sets (
    (c1, c2),
    (c1),
    (c2),
    ()
  )
order by
  c1, c2, g0, g1, g2, g3;
----
a A 0 0 0 0
a NULL 0 1 1 2
b B 0 0 0 0
b NULL 0 1 1 2
NULL A 1 0 2 1
NULL B 1 0 2 1
NULL NULL 1 1 3 3

# grouping_with_cube
query TTIIII
select
  c1,
  c2,
  grouping(c1) as g0,
  grouping(c2) as g1,
  grouping(c1, c2) as g2,
  grouping(c2, c1) as g3
from
  test
group by
  cube(c1, c2)
order by
  c1, c2, g0, g1, g2, g3;
----
a A 0 0 0 0
a NULL 0 1 1 2
b B 0 0 0 0
b NULL 0 1 1 2
NULL A 1 0 2 1
NULL B 1 0 2 1
NULL NULL 1 1 3 3

# grouping_with_rollup
query TTIIII
select
  c1,
  c2,
  grouping(c1) as g0,
  grouping(c2) as g1,
  grouping(c1, c2) as g2,
  grouping(c2, c1) as g3
from
  test
group by
  rollup(c1, c2)
order by
  c1, c2, g0, g1, g2, g3;
----
a A 0 0 0 0
a NULL 0 1 1 2
b B 0 0 0 0
b NULL 0 1 1 2
NULL NULL 1 1 3 3

query TTIIIIIIII
select
  c1,
  c2,
  c3,
  grouping(c1) as g0,
  grouping(c2) as g1,
  grouping(c1, c2) as g2,
  grouping(c2, c1) as g3,
  grouping(c1, c2, c3) as g4,
  grouping(c2, c3, c1) as g5,
  grouping(c3, c2, c1) as g6
from
  test
group by
  rollup(c1, c2, c3)
order by
  c1, c2, g0, g1, g2, g3, g4, g5, g6;
----
a A 1 0 0 0 0 0 0 0
a A NULL 0 0 0 0 1 2 4
a NULL NULL 0 1 1 2 3 6 6
b B 2 0 0 0 0 0 0 0
b B NULL 0 0 0 0 1 2 4
b NULL NULL 0 1 1 2 3 6 6
NULL NULL NULL 1 1 3 3 7 7 7

# grouping_with_add
query TTI
select
  c1,
  c2,
  grouping(c1)+grouping(c2) as g0
from
  test
group by
  rollup(c1, c2)
order by
  c1, c2, g0;
----
a A 0
a NULL 1
b B 0
b NULL 1
NULL NULL 2

#grouping_with_windown_function
query TTIII
select
  c1,
  c2,
  count(c1) as cnt,
  grouping(c1)+ grouping(c2) as g0,
  rank() over (
    partition by grouping(c1)+grouping(c2),
    case when grouping(c2) = 0 then c1 end
    order by
      count(c1) desc
  ) as rank_within_parent
from
  test
group by
  rollup(c1, c2)
order by
  c1,
  c2,
  cnt,
  g0 desc,
  rank_within_parent;
----
a A 1 0 1
a NULL 1 1 1
b B 1 0 1
b NULL 1 1 1
NULL NULL 2 2 1

# grouping_with_non_columns
query TIIIII
select
  c1,
  c3 + 1 as c3_add_one,
  grouping(c1) as g0,
  grouping(c3 + 1) as g1,
  grouping(c1, c3 + 1) as g2,
  grouping(c3 + 1, c1) as g3
from
  test
group by
  grouping sets (
    (c1, c3 + 1),
    (c3 + 1),
    (c1)
  )
order by
  c1, c3_add_one, g0, g1, g2, g3;
----
a 2 0 0 0 0
a NULL 0 1 1 2
b 3 0 0 0 0
b NULL 0 1 1 2
NULL 2 1 0 2 1
NULL 3 1 0 2 1

# postgres allows grouping function for GROUP BY without GROUPING SETS/ROLLUP/CUBE
query TI
select c1, grouping(c1) from test group by c1 order by c1;
----
a 0
b 0

statement error c2.*not in grouping columns
select c1, grouping(c2) from test group by c1;

statement error c2.*not in grouping columns
select c1, grouping(c1, c2) from test group by CUBE(c1);

statement error zero arguments
select c1, grouping() from test group by CUBE(c1);

# grouping_sets_with_empty_set
query I
SELECT COUNT(*) FROM test GROUP BY GROUPING SETS (());
----
2

# grouping_sets_with_empty_set
query I
SELECT SUM(v1) FROM generate_series(10) AS t1(v1) GROUP BY GROUPING SETS(())
----
55

# ROLLUP with empty input should still produce grand total row
query TI
SELECT c1, COUNT(*) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1);
----
NULL 0

# CUBE with empty input should still produce grand total row
query TI
SELECT c1, COUNT(*) FROM test WHERE c3 < 0 GROUP BY CUBE(c1);
----
NULL 0

# GROUPING SETS with empty set and empty input
query TI
SELECT c1, COUNT(*) FROM test WHERE c3 < 0 GROUP BY GROUPING SETS((), (c1));
----
NULL 0

# ROLLUP with multiple columns and empty input
query TTI
SELECT c1, c2, COUNT(*) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1, c2);
----
NULL NULL 0

# SUM should return NULL for empty input with ROLLUP
query TII
SELECT c1, SUM(c3), COUNT(c3) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1);
----
NULL NULL 0

# Multiple aggregates with empty ROLLUP
query TRII
SELECT c1, AVG(c3), MIN(c3), MAX(c3) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1);
----
NULL NULL NULL NULL

# Duplicate empty grouping sets with empty input should produce multiple rows
query I
SELECT COUNT(*) FROM test WHERE c3 < 0 GROUP BY GROUPING SETS((), ());
----
0
0

# Triple duplicate empty grouping sets, empty input
query I rowsort
SELECT count(*) FROM test WHERE c3 < 0 GROUP BY GROUPING SETS((), (), ());
----
0
0
0

# Mixed grouping sets with duplicate empty sets, empty input
query TTI rowsort
SELECT c1, c2, count(*) FROM test WHERE c3 < 0 GROUP BY GROUPING SETS((c1), (), (c2), ());
----
NULL NULL 0
NULL NULL 0

# CUBE on 2 cols with empty input (includes () once)
query TTII rowsort
SELECT c1, c2, count(*), sum(c3) FROM test WHERE c3 < 0 GROUP BY CUBE(c1, c2);
----
NULL NULL 0 NULL

# ROLLUP on 3 cols with empty input
query TTII rowsort
SELECT c1, c2, c3, count(*) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1, c2, c3);
----
NULL NULL NULL 0

# Only empty grouping set, no group columns, empty input
query IIRII
SELECT count(*), sum(c3), avg(c3), min(c3), max(c3) FROM test WHERE c3 < 0 GROUP BY GROUPING SETS(());
----
0 NULL NULL NULL NULL

# ROLLUP on truly empty table
statement ok
CREATE TABLE empty_table (a VARCHAR, b INT);

query TII
SELECT a, count(*), sum(b) FROM empty_table GROUP BY ROLLUP(a);
----
NULL 0 NULL

# CUBE on truly empty table
query TII
SELECT a, count(*), sum(b) FROM empty_table GROUP BY CUBE(a);
----
NULL 0 NULL

# ROLLUP with all-NULL data
statement ok
INSERT INTO empty_table VALUES (NULL, NULL), (NULL, NULL);

query TIII rowsort
SELECT a, count(*), sum(b), count(b) FROM empty_table GROUP BY ROLLUP(a);
----
NULL 2 NULL 0
NULL 2 NULL 0

statement ok
DROP TABLE empty_table;

# Mixed empty/non-empty grouping sets with data
query TTI rowsort
SELECT c1, c2, count(*) FROM test GROUP BY GROUPING SETS((c1), (), (c2), ());
----
NULL A 1
NULL B 1
NULL NULL 2
NULL NULL 2
a NULL 1
b NULL 1

# count(distinct) with ROLLUP empty input
query TI
SELECT c1, count(distinct c3) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1);
----
NULL 0

# ROLLUP with single-row input (boundary: minimal non-empty)
query TII rowsort
SELECT c1, count(*), sum(c3) FROM test WHERE c1 = 'a' AND c2 = 'A' GROUP BY ROLLUP(c1);
----
NULL 1 1
a 1 1

# GROUPING(c1) with ROLLUP empty input
query TII
SELECT c1, grouping(c1), count(*) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1);
----
NULL 1 0

# count with FILTER and empty input ROLLUP
query TII
SELECT c1, count(*) FILTER (WHERE c3 > 5), sum(c3) FROM test WHERE c3 < 0 GROUP BY ROLLUP(c1);
----
NULL 0 NULL
