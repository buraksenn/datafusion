# basic split by whitespace
query ?
SELECT regexp_split_to_array('hello world', '\s+');
----
[hello, world]

# split by comma
query ?
SELECT regexp_split_to_array('one,two,three', ',');
----
[one, two, three]

# no match returns single-element array
query ?
SELECT regexp_split_to_array('hello', 'xyz');
----
[hello]

# case-insensitive flag
query ?
SELECT regexp_split_to_array('HeLLo', 'l', 'i');
----
[He, , o]

# NULL value
query ?
SELECT regexp_split_to_array(NULL, '\s+');
----
NULL

# NULL pattern returns NULL
query ?
SELECT regexp_split_to_array('hello', NULL);
----
NULL

# empty string
query ?
SELECT regexp_split_to_array('', '\s+');
----
[]

# empty pattern splits into characters
query ?
SELECT regexp_split_to_array('abc', '');
----
[a, b, c]

# pattern at start and end produces empty strings
query ?
SELECT regexp_split_to_array(',a,,b,', ',');
----
[, a, , b, ]

# unicode characters
query ?
SELECT regexp_split_to_array('Düsseldorf Köln Москва', '\s+');
----
[Düsseldorf, Köln, Москва]

# multiple character pattern
query ?
SELECT regexp_split_to_array('fooXYZbarXYZbaz', 'XYZ');
----
[foo, bar, baz]

# regex pattern with quantifier
query ?
SELECT regexp_split_to_array('foo123bar456baz', '\d+');
----
[foo, bar, baz]

# global flag silently ignored (split is inherently global)
query ?
SELECT regexp_split_to_array('hello world', '\s+', 'g');
----
[hello, world]

# combined flags with global
query ?
SELECT regexp_split_to_array('HeLLo WoRLd', 'l', 'ig');
----
[He, , o WoR, d]

# multi-line flag
query ?
SELECT regexp_split_to_array('foo
bar', '\n');
----
[foo, bar]

# column-based tests
statement ok
CREATE TABLE regexp_split_test (str VARCHAR, pattern VARCHAR, flags VARCHAR) AS VALUES
    ('hello world',       '\s+',   NULL),
    ('foo,bar,baz',       ',',     NULL),
    ('HeLLo',             'l',     'i'),
    ('abc',               'xyz',   NULL);

query ?
SELECT regexp_split_to_array(str, pattern) FROM regexp_split_test;
----
[hello, world]
[foo, bar, baz]
[HeLLo]
[abc]

query ?
SELECT regexp_split_to_array(str, pattern, flags) FROM regexp_split_test;
----
[hello, world]
[foo, bar, baz]
[He, , o]
[abc]

statement ok
DROP TABLE regexp_split_test;

# Utf8View tests
query ?
SELECT regexp_split_to_array(arrow_cast('hello world', 'Utf8View'), arrow_cast('\s+', 'Utf8View'));
----
[hello, world]

query ?
SELECT regexp_split_to_array(arrow_cast('HeLLo', 'Utf8View'), arrow_cast('l', 'Utf8View'), arrow_cast('i', 'Utf8View'));
----
[He, , o]

# LargeUtf8 tests
query ?
SELECT regexp_split_to_array(arrow_cast('hello world', 'LargeUtf8'), arrow_cast('\s+', 'LargeUtf8'));
----
[hello, world]

query ?
SELECT regexp_split_to_array(arrow_cast('foo-bar', 'LargeUtf8'), arrow_cast('-', 'LargeUtf8'));
----
[foo, bar]
