## SQL tests for CREATE MACRO

# Basic scalar macro with addition
statement ok
CREATE MACRO add_macro(a, b) AS a + b;

query I
SELECT add_macro(1, 2);
----
3

# Macro with default argument
statement ok
CREATE MACRO add_default(a, b := 5) AS a + b;

query I
SELECT add_default(10);
----
15

query I
SELECT add_default(10, 20);
----
30

# Macro with CASE expression
statement ok
CREATE MACRO ifelse(a, b, c) AS CASE WHEN a THEN b ELSE c END;

query I
SELECT ifelse(true, 1, 2);
----
1

query I
SELECT ifelse(false, 1, 2);
----
2

# Macro works with table columns
statement ok
CREATE TABLE t1 (x BIGINT, y BIGINT);

statement ok
INSERT INTO t1 VALUES (1, 2), (3, 4);

query I rowsort
SELECT add_macro(x, y) FROM t1;
----
3
7

# OR REPLACE
statement ok
CREATE OR REPLACE MACRO add_macro(a, b) AS a + b + 1;

query I
SELECT add_macro(1, 2);
----
4

# TEMP macro
statement ok
CREATE TEMP MACRO temp_add(a, b) AS a + b;

query I
SELECT temp_add(3, 4);
----
7

# Drop macro (uses DROP FUNCTION)
statement ok
DROP FUNCTION add_macro;

query error
SELECT add_macro(1, 2);

# DROP FUNCTION IF EXISTS works
statement ok
DROP FUNCTION IF EXISTS nonexistent_macro;

# Table macro not yet supported
statement error DataFusion error: This feature is not implemented: Table macros are not yet supported
CREATE MACRO sel(col) AS TABLE SELECT col FROM t1;

# Cleanup
statement ok
DROP TABLE t1;

statement ok
DROP FUNCTION add_default;

statement ok
DROP FUNCTION ifelse;

statement ok
DROP FUNCTION temp_add;
